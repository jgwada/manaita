{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "manaita.vercel.app" }],
      "destination": "https://i-love-restaurant.vercel.app/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/fetch-news",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/calendar",
      "schedule": "0 0 1 * *"
    }
  ]
}
